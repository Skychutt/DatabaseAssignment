@startuml EER图
' 超类
entity 用户 {
    用户ID(PK)
    用户名
}
entity 学生 {
    班级
    入学时间
}



entity 管理员 {
    权限等级
}

' 子类继承（EER泛化）
用户 <|-- 学生
用户 <|-- 管理员



' 弱实体
entity 订单明细 <<弱实体>> {
    明细编号
    数量
}
entity 订单 {
    订单号(PK)
    下单时间
}

订单 -- 包含 : 依赖
订单明细 -- 包含

' 多值属性示意
entity 社团 {
    社团编号
    成员名单(多值)
}
@enduml